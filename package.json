    "protoc-tsproto-nicegrpc": "./node_modules/.bin/grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./external/src --ts_proto_opt=outputServices=nice-grpc,outputServices=generic-definitions,useExactTypes=false --proto_path=./external ./external/degen_server.proto",
    "protoc-tsproto-nicegrpc-comment": "cd external; npm init; tsc --init; npm i @bufbuild/protobuf nice-grpc-common; npx denoify; rename deno_. dir on windows without period since it breaks stuff; deno run thatFile; then deno run ./supabase/functions/grpc-relay/index.ts; then copy the ts file to the supabase/functions/grpc-relay/ directory and reference it in code",
    "build:bin": "tsc -p bin/tsconfig.json",
    "bin": "node bin/dist/index.js",
    "bin:dev": "tsx bin/src/index.ts"
  },
